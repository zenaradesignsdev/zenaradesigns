# Environment Variables for Zenara Designs
# Copy this file to .env.local and fill in your actual values

# Resend API Configuration
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# CORS Configuration
# The allowed origin for API requests (your production domain)
ALLOWED_ORIGIN=https://zenaradesigns.com

# Optional: Development overrides
# For local development, you might want to use:
# ALLOWED_ORIGIN=http://localhost:5173

# ─── Google Search Console Audit (scripts/gsc-audit.js) ───────────────────────
# Your GSC property URL (must match exactly what's registered in Search Console)
GSC_SITE_URL=https://zenaradesigns.com/

# Service account credentials — choose ONE method:
#
# Method 1 (recommended): Paste the full JSON content of your service account key
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"..."}
#
# Method 2: Path to the downloaded service account JSON key file
# GOOGLE_SERVICE_ACCOUNT_PATH=./secrets/gsc-service-account.json

# Optional tuning
# GSC_OUTPUT_FILE=gsc-audit-report.md   # Output filename (default: gsc-audit-report.md)
# GSC_MAX_URLS=100                       # Max URLs to inspect individually (default: 100)
# GSC_DAYS=28                            # Days of analytics history to pull (default: 28)

# ─── PageSpeed Insights Audit (scripts/pagespeed-audit.js) ───────────────────
PSI_URL=https://zenaradesigns.com
PSI_API_KEY=your_google_api_key_here
# PSI_STRATEGY=both         # mobile | desktop | both (default: both)
# PSI_OUTPUT_FILE=pagespeed-audit-report.md
